# NewsFlow Environment Variables
# Copy this file to .env.local for local development

# API URL Configuration
# ---------------------
# Override the API endpoint URL. If not set, defaults to '/api' (relative path).
#
# Use cases:
# - Local development with local API: (leave unset or comment out)
# - Local development with Vercel API: NEXT_PUBLIC_API_URL=https://your-app.vercel.app/api
# - Production (Vercel/Netlify): usually not needed, keep default

# NEXT_PUBLIC_API_URL=https://your-app.vercel.app/api

# Note: NEXT_PUBLIC_ prefix makes the variable available in the browser.
# This is required because the API call happens on the client side.
