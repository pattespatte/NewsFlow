# NewsFlow RSS Reader - Environment Configuration Example
# Copy this file to .env and configure as needed

# API Configuration
# Choose one of the following modes:

# 1. Local API Server (default) - Leave empty to use /api relative path
#    Requires running: cd api-server && npm run dev
# NEXT_PUBLIC_API_URL=

# 2. Production API (recommended for dev) - Uses deployed Vercel API
# NEXT_PUBLIC_API_URL=https://news-flow-rho.vercel.app

# 3. Custom Local API Port - If running API server on different port
# NEXT_PUBLIC_API_URL=http://localhost:3001

# Note: /api path is appended automatically if not already included in the URL
NEXT_PUBLIC_API_URL=
